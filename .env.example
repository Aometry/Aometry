# Bot Configuration
BOT_TOKEN=your_bot_token_here
DEV_ID=your_user_id_here

# Optional: MongoDB connection (defaults to SQLite if left empty)
DB_URL=

# API and Web Management
WEBUI_PORT=3000
API_KEY=your_secure_api_key_here
# Comma-separated list of origins allowed to access the API
ALLOWED_ORIGINS=https://aometry.finneh.xyz,http://localhost:4321

# Runtime Settings (configure via dashboard after bot is running)
SYSTEM_LOGS_CHANNEL=
LOGS_CHANNEL=

# Optional: sync token for `/repo sync-module` and API sync endpoint
MODULE_SYNC_GITHUB_TOKEN=github_pat_xxx
